{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "long_term_logic_review.v1.0.0",
  "title": "Long Term Logic Review Draft",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "draft_status",
    "logic_status",
    "summary"
  ],
  "properties": {
    "draft_status": {
      "type": "string",
      "enum": ["draft", "validated", "failed"]
    },
    "review_status": {
      "type": "string",
      "enum": ["pending_review", "approved", "rejected"]
    },
    "logic_status": {
      "type": "string",
      "enum": ["valid", "weakened", "invalid", "insufficient_information"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "updatedAt": {
      "type": "string"
    },
    "validUntil": {
      "type": "string"
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "investmentThesis": {
      "type": "string"
    },
    "coreDrivers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "fundamentalSupport": {
      "type": "array",
      "items": { "type": "string" }
    },
    "valuationView": {
      "type": "string"
    },
    "longTermRisks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "invalidationConditions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "nextReviewDate": {
      "type": "string"
    },
    "informationGaps": {
      "type": "array",
      "items": { "type": "string" }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}

